{
	"manifest_version": 3,
	"name": "JetPunkSolver",
	"version": "1.0.0",
	"description": "Browser Extension to automatically solve JetPunk Quizzes",
	"host_permissions": [
		"https://*.jetpunk.com/*"
	],
	"content_scripts": [
		{
			"matches": [
				"https://*.jetpunk.com/*"
			],
			"js": [
				"content/index.js"
			]
		},
		{
			"matches": [
				"https://*.jetpunk.com/minigames/typing-speed-test"
			],
			"js": [
				"content/inject-override-timer.js"
			],
			"run_at": "document_start"
		}
	],
	"web_accessible_resources": [
		{
			"matches": [
				"https://*.jetpunk.com/*"
			],
			"resources": [
				"resources/override-timer.js"
			]
		}
	]
}
